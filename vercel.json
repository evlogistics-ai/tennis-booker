{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "regions": ["iad1"],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "rewrites": [
    { "source": "/api/test", "destination": "/api/test" },
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
